# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/serverImagesDB

# Backend image server URL
# Used server-side for proxying requests to the CDN/upload API
API_URL=http://localhost:5200

# Backend image server URL (client-visible)
# Defaults to http://localhost:5200 if not set
NEXT_PUBLIC_API_URL=http://localhost:5200

# Public base URL of this Next.js app
# Used for generating proxy URLs and Open Graph metadata
# Example: https://images.example.com
NEXT_PUBLIC_BASE_URL=

# Cloudflare Turnstile site key (required for uploads)
# Get from https://dash.cloudflare.com -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Salt for hashing IP addresses before storing view history
# Generate a strong random string and keep it secret
IP_HASH_SALT=

# Shared secret with the backend. The proxy sends it so sessions that already
# passed Turnstile can keep uploading without a new challenge.
# Must match INTERNAL_API_SECRET on the backend. Keep secret.
INTERNAL_API_SECRET=
